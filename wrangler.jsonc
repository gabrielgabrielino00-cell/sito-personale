{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "elettronica51",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-16",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "vqpeeeeeee.xyz",
      "custom_domain": true
    }
  ]
}